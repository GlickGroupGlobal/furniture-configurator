PORT=3001

# Required when NODE_ENV=production. Use a long random value.
SESSION_SECRET=replace-with-a-long-random-string

# Optional. If set, this password is used instead of the password stored in the local database.
ADMIN_PASSWORD=

# Optional. Defaults to server/data/db.json.
FURNITURE_DB_PATH=

# Required for the "autobuild from a photo" feature (off by default — turn it
# on in Admin > Pricing > Beta features once this is set). Get a key at
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. Vision-capable model used for photo analysis.
ANTHROPIC_VISION_MODEL=claude-sonnet-5
